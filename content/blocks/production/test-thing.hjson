# Mandatory, defines the block as a multicrafter
type: MultiCrafter

# You can define any block variable below, as long as it is supported by the game.
name: "test thing"
description: "recipe testing"
size: 2
itemCapacity: 15
health: 200

# The library specific variables
jsonRecipes: [
    {
        name: first-basic
        input: {
            items: ["graphite/10"]
        }
        output: {
            items: ["silicon/1"]
        }
        craftTime: 60  # = 1 second
        unlocked: true
    }
    {
        name: second-basic
        input: {
            items: ["titanium/2"]
            liquids: ["water/100"]
        }
        output: {
            items: ["plastanium/1"]
        }
        craftTime: 600  # = 10 seconds

        # This recipe will be locked until the player unlock this research
        unlocked: false
        research: core-shard
        researchRequirements: ["titanium/500", "plastanium/50"]
    }
]


# Back to the default game variables
requirements: ["copper/10"]
category: "crafting"
