# Mandatory, defines the block as a multicrafter
type: MultiCrafter

# You can define any block variable below, as long as it is supported by the game.
size: 2
itemCapacity: 15
health: 200
name: testing thing
description: recipe testing stuff


# The library specific variables
jsonRecipes: [ # /!\ 'recipes' won't work as it is only for internal and Java mod use.
    # All default values, they are all (technically) optional
    {
        # Will cause a conflict if you have multiple recipes with the same name
        name: empty-recipe

        # From ticks to seconds: 80 / 60 = 1.33 seconds
        # From seconds to ticks: 1.33 * 60 = 80 ticks
        craftTime: 90  # Value is per tick! Multiply the desired value (in seconds) by 60 to get the correct amount (the game run at 60 ticks per second).
        input: {
            items: [
   "copper/2",
   "coal/1"
            ]
            liquids: [
   "water/0.1"
            ] # Values are per tick! Divide the desired amount by 60 to get the correct amount (the game run at 60 ticks per second)
            power: 0.5 # Value is per tick! Divide the desired amount by 60 to get the correct amount (the game run at 60 ticks per second)
            heat: 0
            // payloads: [] # NOT SUPPORTED YET! IT WON'T DO ANYTHING!
        }
        output: {
            items: [
   "silicon/4"
            ]
            liquids: [
   "slag/0.05"
            ] # Values are per tick! Divide the desired amount by 60 to get the correct amount (the game run at 60 ticks per second)
            power: 0 # Value is per tick! Divide the desired amount by 60 to get the correct amount (the game run at 60 ticks per second)
            heat: 2
            // payloads: [] # NOT SUPPORTED YET! IT WON'T DO ANYTHING!
        }
        # Example for amount to amount/tick conversion:
        #     10 water/second = 10 / 60 = 0.167 water/tick
        #     0.83 water/tick = 0.83 * 60 = 50 water/second
        # It works for power or liquids quantity.

        craftEffect: none
        updateEffect: none
        updateEffectChance: 0.04
        updateEffectSpread: 4
        warmupSpeed: 0.019

        # Only for heat based block
        warmupRate: 0.15
        overheatScale: 1
        maxEfficiency: 4

        # If false (by default), the recipe will need to be researched to unlock. Useful for recipes that needs items unlocked later in your progression.
        unlocked: false

        # Any unlockable content, including recipes from this or other block (must have been loaded before!). The content *has* to be in the research tree.
        research: core-shard
        # Optional. If not set, the recipe will be unlocked automatically if the parent node (defined above) is unlocked.
        researchRequirements: ["lead/10"]
    }
]


# Back to the default game variables
requirements: ["copper/10"]
category: "crafting"
